# Copy to `web/.env.local` for local development (never commit `.env.local`).
# Restart `npm run dev` after any change.
#
# Supabase → Project Settings → API:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (instructor + student self-registration APIs). Same project → "service_role" secret (NOT anon key):
SUPABASE_SERVICE_ROLE_KEY=

# GEC access requests: College Admin (COTE) college id when GEC user has no college (default matches seed CTE):
# NEXT_PUBLIC_GEC_APPROVAL_COLLEGE_ID=col-tech-eng

# Optional: email temporary passwords via https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
